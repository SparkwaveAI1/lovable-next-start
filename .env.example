# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# GAME SDK
GAME_API_KEY=

# To run locally:
# GAME_API_KEY=gam_xxx npm run smoke
# GAME_API_KEY=gam_xxx npm run twitter-smoke

# LinkedIn OAuth Integration (Phase 1)
# Create a LinkedIn app at https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Random 32+ char string used to sign OAuth state parameter (CSRF protection)
LINKEDIN_STATE_SECRET=change-me-to-a-random-secret-string

# Random 32+ char string used for pgcrypto pgp_sym_encrypt of OAuth tokens
LINKEDIN_ENCRYPTION_KEY=change-me-to-a-random-encryption-key

# Public URL of the app (used to construct OAuth callback URL)
APP_URL=https://sparkwaveai.app