    {
      "parameters": {
        "jsCode": "// Check if current time is within business hours (8AM–6PM ET)\nconst now = new Date();\nconst etHour = parseInt(\n  new Intl.DateTimeFormat('en-US', {\n    timeZone: 'America/New_York',\n    hour: 'numeric',\n    hour12: false\n  }).format(now)\n);\n\nconst etTime = new Intl.DateTimeFormat('en-US', {\n  timeZone: 'America/New_York',\n  hour: '2-digit',\n  minute: '2-digit',\n  hour12: false\n}).format(now);\n\nif (etHour < 8 || etHour >= 18) {\n  // Outside business hours — stop workflow\n  return [];\n}\n\nreturn [{ json: { et_hour: etHour, et_time: etTime, timestamp: now.toISOString() } }];\n"
      },
      "id": "time-check",
      "name": "Time Check (8AM-6PM ET)",
