    {
      "parameters": {
        "jsCode": "// Merge step data with lead data\nconst step = $('Loop Over Steps').item.json;\nconst leads = $input.all();\nconst lead = leads.length > 0 ? leads[0].json : null;\n\nif (!lead || !Array.isArray(lead) || lead.length === 0) {\n  // No lead found - treat as missing phone\n  return [{\n    json: {\n      step_id: step.id,\n      submission_id: step.submission_id,\n      step_name: step.step_name,\n      message_content: step.message_content,\n      retry_count: step.retry_count || 0,\n      has_phone: false,\n      phone: null,\n      first_name: null,\n      skip_reason: 'lead_not_found'\n    }\n  }];\n}\n\n// lead is an array from Supabase REST API\nconst leadData = Array.isArray(lead) ? lead[0] : lead;\nconst hasPhone = !!(leadData.phone && leadData.phone.trim());\n\nreturn [{\n  json: {\n    step_id: step.id,\n    submission_id: step.submission_id,\n    step_name: step.step_name,\n    message_content: step.message_content,\n    retry_count: step.retry_count || 0,\n    has_phone: hasPhone,\n    phone: hasPhone ? leadData.phone.trim() : null,\n    first_name: leadData.first_name || 'there',\n    last_name: leadData.last_name || '',\n    email: leadData.email || null,\n    skip_reason: hasPhone ? null : 'no_phone'\n  }\n}];\n"
      },
