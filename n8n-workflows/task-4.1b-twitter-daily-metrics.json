    {
      "id": "node-get-date",
      "name": "Get ET Date",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "jsCode": "// DST-safe ET date using Intl.DateTimeFormat (same pattern as Task 4.1)\nconst now = new Date();\nconst etDateStr = new Intl.DateTimeFormat('en-CA', {\n  timeZone: 'America/New_York',\n  year: 'numeric', month: '2-digit', day: '2-digit'\n}).format(now);\n\nfunction getETOffset(d) {\n  const s = d.toLocaleString('en-US', { timeZone: 'America/New_York', timeZoneName: 'shortOffset' });\n  const m = s.match(/GMT([+-]\\d+)/);\n  if (!m) return '-05:00';\n  const h = parseInt(m[1]);\n  return (h < 0 ? '-' : '+') + String(Math.abs(h)).padStart(2,'0') + ':00';\n}\n\nconst offset = getETOffset(now);\nconst startUtc = new Date(etDateStr + 'T00:00:00' + offset).toISOString();\nconst endUtc = new Date(new Date(startUtc).getTime() + 86399999).toISOString();\nconst date = etDateStr;\n\nreturn [{ json: { date, startUtc, endUtc } }];"
      }
    },
