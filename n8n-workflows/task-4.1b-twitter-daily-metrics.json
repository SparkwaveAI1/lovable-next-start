    {
      "id": "node-calc-metrics",
      "name": "Calculate Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300],
      "parameters": {
        "jsCode": "const posts = $('Get Twitter Posts').all().map(i => i.json);\nconst gates = $input.all().map(i => i.json);\nconst date = $('Get ET Date').first().json.date;\n\nconst accounts = ['rico', 'persona', 'charx', 'barnum'];\nconst postCounts = {};\nfor (const a of accounts) postCounts[a] = posts.filter(p => p.account === a).length;\n\nconst totalGates = gates.length;\nconst passedGates = gates.filter(g => g.passed === true).length;\nconst qualityRate = totalGates > 0 ? Math.round((passedGates / totalGates) * 10000) / 10000 : 0;\n\nreturn [{\n  json: {\n    date,\n    posts_rico: postCounts.rico || 0,\n    posts_persona: postCounts.persona || 0,\n    posts_charx: postCounts.charx || 0,\n    posts_barnum: postCounts.barnum || 0,\n    quality_gate_pass_rate: qualityRate,\n    quality_gates_total: totalGates\n  }\n}];"
      }
    },
    {
      "id": "node-build-metrics",
      "name": "Build Metrics Array",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 300],
      "parameters": {
        "jsCode": "const d = $input.first().json;\nreturn [{\n  json: [\n    { system: 'twitter', metric: 'posts_rico',             date: d.date, actual: d.posts_rico,             target: 5,    notes: null },\n    { system: 'twitter', metric: 'posts_persona',          date: d.date, actual: d.posts_persona,          target: 5,    notes: null },\n    { system: 'twitter', metric: 'posts_charx',            date: d.date, actual: d.posts_charx,            target: 5,    notes: null },\n    { system: 'twitter', metric: 'posts_barnum',           date: d.date, actual: d.posts_barnum,           target: 5,    notes: null },\n    { system: 'twitter', metric: 'comments_total',         date: d.date, actual: 0,                        target: 25,   notes: 'comment tracking not yet in DB' },\n    { system: 'twitter', metric: 'quality_gate_pass_rate', date: d.date, actual: d.quality_gate_pass_rate, target: 0.85, notes: d.quality_gates_total === 0 ? 'no gate data' : null },\n    { system: 'twitter', metric: 'manual_deletions',       date: d.date, actual: 0,                        target: 0,    notes: 'detection not yet implemented' }\n  ]\n}];"
      }
