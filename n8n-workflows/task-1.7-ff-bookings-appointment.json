    {
      "parameters": {
        "jsCode": "const appt = $input.item.json;\nconst sessionStart = new Date(appt.session_start);\n\nconst addDays = (date, days) => {\n  const d = new Date(date);\n  d.setDate(d.getDate() + days);\n  return d.toISOString();\n};\n\nconst steps = [\n  {\n    appointment_id: appt.id,\n    step_name: 'pre_class_reminder',\n    step_order: 1,\n    channel: 'sms',\n    scheduled_for: addDays(sessionStart, -1),\n    status: 'pending',\n    message_content: `Hi ${appt.contact_name || 'there'}! Just a reminder about your ${appt.service_name || 'class'} tomorrow at Fight Flow Academy. We look forward to seeing you! Reply STOP to opt out.`\n  },\n  {\n    appointment_id: appt.id,\n    step_name: 'post_class_checkin',\n    step_order: 2,\n    channel: 'sms',\n    scheduled_for: addDays(sessionStart, 1),\n    status: 'pending',\n    message_content: `Hey ${appt.contact_name || 'there'}! Hope you enjoyed your ${appt.service_name || 'class'} at Fight Flow Academy! How did it go? We'd love to hear from you.`\n  },\n  {\n    appointment_id: appt.id,\n    step_name: 'day3_followup',\n    step_order: 3,\n    channel: 'sms',\n    scheduled_for: addDays(sessionStart, 3),\n    status: 'pending',\n    message_content: `Hi ${appt.contact_name || 'there'}, it's been a few days since your class at Fight Flow Academy. Are you interested in continuing your training? We have great membership options available!`\n  },\n  {\n    appointment_id: appt.id,\n    step_name: 'week1_checkin',\n    step_order: 4,\n    channel: 'sms',\n    scheduled_for: addDays(sessionStart, 7),\n    status: 'pending',\n    message_content: `Hey ${appt.contact_name || 'there'}! A week has passed since your class at Fight Flow Academy. Ready to take the next step in your martial arts journey? Reply YES to learn about our memberships!`\n  }\n];\n\nreturn steps.map(step => ({ json: step }));"
      },
