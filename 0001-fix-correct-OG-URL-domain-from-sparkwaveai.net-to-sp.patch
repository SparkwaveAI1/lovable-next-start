       "foundingDate": "2023",
       "founder": {"@type": "Person", "name": "Scott Johnson"},
@@ -31,10 +31,10 @@
     
     <!-- Open Graph -->
     <meta property="og:type" content="website" />
-    <meta property="og:url" content="https://sparkwaveai.app" />
+    <meta property="og:url" content="https://sparkwave-ai.com/" />
     <meta property="og:title" content="Sparkwave AI - 10x Your Output, Zero Extra Hours" />
     <meta property="og:description" content="Custom AI automation that multiplies your productivity. Do what took a team of 10, with just you." />
