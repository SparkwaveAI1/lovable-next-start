     <meta property="og:site_name" content="Sparkwave AI" />
 
     <!-- Twitter Cards -->
@@ -43,7 +43,7 @@
     <meta name="twitter:creator" content="@ScottSparkwave" />
     <meta name="twitter:title" content="Sparkwave AI - 10x Your Output, Zero Extra Hours" />
     <meta name="twitter:description" content="Custom AI automation that multiplies your productivity. Do what took a team of 10, with just you." />
-    <meta name="twitter:image" content="https://sparkwaveai.app/og-image.png" />
+    <meta name="twitter:image" content="https://sparkwave-ai.com/og-image.png" />
 </head>
 
